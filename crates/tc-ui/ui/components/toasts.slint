// components/toasts.slint — Toast notification overlay.

import { ThemeColorsProvider } from "theme/colors.slint";
import { ToastItem } from "types.slint";

export component Toasts inherits Rectangle {
    in property <[ToastItem]> toasts;

    background: transparent;

    VerticalLayout {
        alignment: end;
        padding-right: 16px;
        padding-bottom: 100px;
        spacing: 6px;

        for toast[i] in root.toasts : Rectangle {
            width: 280px;
            height: 36px;
            border-radius: 6px;
            background: toast-bg-color(toast.level);
            border-width: 1px;
            border-color: toast-border-color(toast.level);

            HorizontalLayout {
                padding-left: 12px;
                padding-right: 12px;
                Text {
                    text: toast.message;
                    font-size: 12px;
                    color: white;
                    vertical-alignment: center;
                    horizontal-alignment: center;
                    horizontal-stretch: 1;
                    overflow: elide;
                }
            }
        }
    }

    function toast-bg-color(level: string) -> color {
        if level == "success" { #1E5032DC }
        else if level == "warning" { #5A4614DC }
        else if level == "error" { #5A1E1EDC }
        else { #32323CDC }
    }

    function toast-border-color(level: string) -> color {
        if level == "success" { #2A8048 }
        else if level == "warning" { #B88A28 }
        else if level == "error" { #B83A3A }
        else { #4A4A52 }
    }
}
