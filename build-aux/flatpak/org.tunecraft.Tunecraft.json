{
    "app-id": "org.tunecraft.Tunecraft",
    "runtime": "org.gnome.Platform",
    "runtime-version": "47",
    "sdk": "org.gnome.Sdk",
    "sdk-extensions": [
        "org.freedesktop.Sdk.Extension.rust-stable"
    ],
    "command": "tunecraft",
    "build-options": {
        "append-path": "/usr/lib/sdk/rust-stable/bin",
        "env": {
            "CARGO_HOME": "/run/build/tunecraft/cargo",
            "RUST_BACKTRACE": "1"
        }
    },
    "finish-args": [
        "--share=ipc",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--socket=pulseaudio",
        "--device=dri",
        "--share=network",
        "--filesystem=xdg-music:ro",
        "--filesystem=host:ro",
        "--filesystem=/run/media:ro",
        "--filesystem=xdg-cache/tunecraft:create",
        "--talk-name=org.freedesktop.Notifications",
        "--talk-name=org.freedesktop.secrets",
        "--own-name=org.mpris.MediaPlayer2.Tunecraft"
    ],
    "modules": [
        {
            "name": "tunecraft",
            "buildsystem": "meson",
            "builddir": true,
            "config-opts": [
                "--buildtype=release"
            ],
            "sources": [
                {
                    "type": "dir",
                    "path": "../.."
                },
                {
                    "type": "file",
                    "path": "Cargo.lock"
                },
                {
                    "type": "shell",
                    "commands": [
                        "cargo fetch --offline 2>/dev/null || true"
                    ]
                }
            ],
            "cleanup": [
                "/share/doc",
                "/share/man",
                "*.la"
            ]
        }
    ]
}
