# Generated by Cargo
# will have compiled files and executables
/target/
/dist/

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which can roughly be
# considered a trash bin for past versions of a PDB file.
*.pdb

# Profiling data
*.profraw

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Binary dependencies (e.g. FFmpeg)
linux-x64

# Exclude specific files
GEMINI.md
rustup-init.sh
