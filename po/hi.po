msgid "Pop"
msgstr "पॉप"

msgid "Bass Boost"
msgstr "बास बूस्ट"

msgid "Lyrics"
msgstr "गीत"

msgid "Fetching lyrics…"
msgstr "गीत लाए जा रहे हैं…"

msgid "No track playing"
msgstr "कोई ट्रैक नहीं बज रहा"

msgid "Professional offline music player for Linux"
msgstr "लिनक्स के लिए पेशेवर ऑफ़लाइन संगीत प्लेयर"

msgid "About Tunecraft"
msgstr "Tunecraft के बारे में"

