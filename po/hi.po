msgid "Play"
msgstr "चलाएं"

msgid "Pause"
msgstr "रोकें"

msgid "Previous"
msgstr "पिछला"

msgid "Next"
msgstr "अगला"

msgid "Shuffle"
msgstr "शफल"

msgid "Repeat"
msgstr "दोहराएं"

