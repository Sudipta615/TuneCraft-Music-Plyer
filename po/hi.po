#. Translators: Dialog heading for creating a new playlist
msgid "New Playlist"
msgstr "नया प्लेलिस्ट"

#. Translators: Dialog body prompting for playlist name
msgid "Enter a name for the new playlist"
msgstr "नए प्लेलिस्ट के लिए नाम दर्ज करें"

msgid "Cancel"
msgstr "रद्द करें"

msgid "Create"
msgstr "बनाएं"

msgid "Preferences"
msgstr "प्राथमिकताएं"

msgid "General"
